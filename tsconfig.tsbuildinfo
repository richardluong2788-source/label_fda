d here on type '{ readonly good: \"Độ phân giải tối thiểu 800×800px\"; readonly bad: \"Ảnh zoom từ xa, chữ bé hơn 1mm trên màn hình\"; }'","category":3,"code":6500}]},{"start":29538,"length":4,"code":2322,"category":1,"messageText":"Type '\"Entire label panel within frame\"' is not assignable to type '\"Toàn bộ mặt nhãn nằm trong khung hình\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":29975,"length":45,"messageText":"The expected type comes from property 'good' which is declared here on type '{ readonly good: \"Toàn bộ mặt nhãn nằm trong khung hình\"; readonly bad: \"Cạnh nhãn bị cắt mất góc\"; }'","category":3,"code":6500}]},{"start":29579,"length":3,"code":2322,"category":1,"messageText":"Type '\"Label edges cut off at corners\"' is not assignable to type '\"Cạnh nhãn bị cắt mất góc\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30022,"length":31,"messageText":"The expected type comes from property 'bad' which is declared here on type '{ readonly good: \"Toàn bộ mặt nhãn nằm trong khung hình\"; readonly bad: \"Cạnh nhãn bị cắt mất góc\"; }'","category":3,"code":6500}]},{"start":29628,"length":4,"code":2322,"category":1,"messageText":"Type '\"File name without special characters: label-front.jpg\"' is not assignable to type '\"Tên file không dấu, không khoảng trắng: label-front.jpg\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30065,"length":63,"messageText":"The expected type comes from property 'good' which is declared here on type '{ readonly good: \"Tên file không dấu, không khoảng trắng: label-front.jpg\"; readonly bad: \"Tên file tiếng Việt có dấu: ảnh nhãn trước.jpg\"; }'","category":3,"code":6500}]},{"start":29691,"length":3,"code":2322,"category":1,"messageText":"Type '\"File name with spaces or accents: my label front.jpg\"' is not assignable to type '\"Tên file tiếng Việt có dấu: ảnh nhãn trước.jpg\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30130,"length":53,"messageText":"The expected type comes from property 'bad' which is declared here on type '{ readonly good: \"Tên file không dấu, không khoảng trắng: label-front.jpg\"; readonly bad: \"Tên file tiếng Việt có dấu: ảnh nhãn trước.jpg\"; }'","category":3,"code":6500}]},{"start":29765,"length":13,"code":2322,"category":1,"messageText":"Type '\"Advanced options to improve accuracy\"' is not assignable to type '\"Tùy chọn nâng cao để tăng độ chính xác\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30198,"length":55,"messageText":"The expected type comes from property 'advancedTitle' which is declared here on type '{ readonly pageTitle: \"Hướng dẫn sử dụng | FDA Label Checker\"; readonly pageDesc: \"Hướng dẫn upload ảnh nhãn sản phẩm đúng cách để AI phân tích tuân thủ FDA chính xác nhất.\"; ... 28 more ...; readonly ctaButton: \"Bắt đầu kiểm tra nhãn\"; }'","category":3,"code":6500}]},{"start":29824,"length":12,"code":2322,"category":1,"messageText":"Type '\"These additional details help AI apply the correct regulations for your product.\"' is not assignable to type '\"Những thông tin bổ sung này giúp AI áp dụng đúng bộ quy định cho sản phẩm của bạn.\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30259,"length":98,"messageText":"The expected type comes from property 'advancedDesc' which is declared here on type '{ readonly pageTitle: \"Hướng dẫn sử dụng | FDA Label Checker\"; readonly pageDesc: \"Hướng dẫn upload ảnh nhãn sản phẩm đúng cách để AI phân tích tuân thủ FDA chính xác nhất.\"; ... 28 more ...; readonly ctaButton: \"Bắt đầu kiểm tra nhãn\"; }'","category":3,"code":6500}]},{"start":29950,"length":5,"code":2322,"category":1,"messageText":"Type '\"Select the correct product category\"' is not assignable to type '\"Chọn đúng danh mục sản phẩm\"'.","relatedInformation":[{"file":"./lib/i18n/vi.ts","start":30387,"length":36,"messageText":"The expected type comes from property 'title' which is declared here on type '{ readonly title: \"Chọn đúng danh mục sản phẩm\"; read